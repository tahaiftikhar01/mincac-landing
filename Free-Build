</nav>

<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     HERO
     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<section class="fb-hero">
  <div class="container">
    <div class="tag"><span class="tag-dot"></span> Limited — 5 Free Builds Per Month</div>
    <h1>We'll build your first automation <span class="accent">for free.</span></h1>
    <p class="hero-sub">Tell us your most annoying manual process. We'll automate it and have it running in your business this week. No catch. You keep it regardless.</p>
  </div>
</section>

<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     HOW IT WORKS
     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<section class="how-strip">
