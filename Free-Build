     JS
     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<script>
(function(){
  /* Cursor */
  var dot=document.getElementById('cursorDot'),ring=document.getElementById('cursorRing'),glow=document.getElementById('cursorGlow');
  var mx=0,my=0,rx=0,ry=0,gx=0,gy=0;
  document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;dot.style.transform='translate('+(mx-4)+'px,'+(my-4)+'px)'});
  function anim(){rx+=(mx-rx)*.15;ry+=(my-ry)*.15;gx+=(mx-gx)*.08;gy+=(my-gy)*.08;ring.style.transform='translate('+(rx-18)+'px,'+(ry-18)+'px)';glow.style.transform='translate('+(gx-150)+'px,'+(gy-150)+'px)';requestAnimationFrame(anim)}
  anim();
  document.querySelectorAll('a,button,.btn,.tool-check,.ex-card,.how-step').forEach(function(el){
    el.addEventListener('mouseenter',function(){ring.classList.add('hovering')});
    el.addEventListener('mouseleave',function(){ring.classList.remove('hovering')});
  });
  /* Nav */
  var nav=document.getElementById('nav');
  window.addEventListener('scroll',function(){if(window.scrollY>60)nav.classList.add('scrolled');else nav.classList.remove('scrolled')});
})();

/* Tool toggle */
function toggleTool(el){
  setTimeout(function(){
    if(el.querySelector('input').checked) el.classList.add('checked');
    else el.classList.remove('checked');
  },10);
}

/* Validation */
function validateForm(){
  var name=document.getElementById('fName').value.trim();
  var email=document.getElementById('fEmail').value.trim();
  var ind=document.getElementById('fIndustry').value;
  var proc=document.getElementById('fProcess').value.trim();
  var ok=name.length>1 && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email) && ind && proc.length>20;
  document.getElementById('submitBtn').disabled=!ok;
}

/* Submit */
function submitForm(){
  /* In production, wire this to your backend / n8n webhook / Google Sheet / email */
  var d={
    name:document.getElementById('fName').value,
    email:document.getElementById('fEmail').value,
    company:document.getElementById('fCompany').value,
    industry:document.getElementById('fIndustry').value,
    tools:Array.from(document.querySelectorAll('.tool-check.checked')).map(function(t){return t.textContent.trim()}).join(', '),
    process:document.getElementById('fProcess').value,
    hours:document.getElementById('fHours').value
  };
  console.log('Free Build Request:',d);

  /* Show success */
  document.getElementById('formState').style.display='none';
  var ss=document.getElementById('successState');
  ss.style.display='block';
  ss.classList.add('active');
  document.getElementById('formCard').scrollIntoView({behavior:'smooth',block:'center'});
}
</script>

