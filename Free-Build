<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Free Automation Build — Mincac</title>
<meta name="description" content="Tell us your most annoying manual process. We'll automate it for free this week. No catch. If you love it, we talk about the rest.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   RESET & BASE
   ═══════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  background:#07070D;color:#E0E0F0;
  font-family:'Inter',system-ui,sans-serif;
  font-size:17px;line-height:1.7;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
  cursor:none;
}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none;cursor:none}
button,.btn{cursor:none}

/* ═══════════════════════════════════════════
   CUSTOM CURSOR
   ═══════════════════════════════════════════ */
.cursor-dot{position:fixed;top:0;left:0;z-index:9999;width:8px;height:8px;border-radius:50%;background:var(--accent);pointer-events:none;transition:transform .08s ease;mix-blend-mode:screen}
.cursor-ring{position:fixed;top:0;left:0;z-index:9998;width:36px;height:36px;border-radius:50%;border:1.5px solid rgba(0,229,176,0.5);pointer-events:none;transition:width .3s ease,height .3s ease,border-color .3s ease,transform .15s ease}
.cursor-ring.hovering{width:56px;height:56px;border-color:rgba(0,229,176,0.8)}
.cursor-glow{position:fixed;top:0;left:0;z-index:9997;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(0,229,176,0.04) 0%,transparent 70%);pointer-events:none;transition:transform .4s cubic-bezier(.16,1,.3,1)}
@media(max-width:768px){
  body{cursor:auto}a,.btn,button{cursor:pointer}
  .cursor-dot,.cursor-ring,.cursor-glow{display:none!important}
}

/* ═══════════════════════════════════════════
   DESIGN TOKENS
   ═══════════════════════════════════════════ */
:root{
  --bg:#07070D;--bg-card:#0C0C18;--bg-elevated:#101024;
  --accent:#00E5B0;--accent-hover:#33FFCC;
  --accent-dim:rgba(0,229,176,0.08);--accent-border:rgba(0,229,176,0.2);
  --border:rgba(255,255,255,0.06);--border-hover:rgba(0,229,176,0.18);
  --text-1:#EAEAF4;--text-2:#A8A8C4;--text-3:#6E6E90;
  --red:#FF4560;--red-dim:rgba(255,69,96,0.08);--red-border:rgba(255,69,96,0.2);
}
h1,h2,h3,h4,h5{font-family:'Sora',sans-serif;line-height:1.12;color:var(--text-1)}
.mono{font-family:'JetBrains Mono',monospace}
.container{max-width:1120px;margin:0 auto;padding:0 24px}
.accent{color:var(--accent)}

/* ═══════════════════════════════════════════
   BUTTONS
   ═══════════════════════════════════════════ */
.btn{display:inline-flex;align-items:center;gap:8px;font-family:'Sora',sans-serif;font-weight:700;border-radius:8px;border:none;transition:all .2s ease;white-space:nowrap;position:relative;overflow:hidden}
.btn-primary{background:var(--accent);color:#07070D;font-size:15px;padding:14px 28px}
.btn-primary:hover{background:var(--accent-hover);transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,229,176,0.25)}
.btn-primary:active{transform:translateY(0)}
.btn-icon{width:16px;height:16px;flex-shrink:0;transition:transform .2s}
.btn:hover .btn-icon{transform:translateX(3px)}
.btn-primary::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);transition:left .5s ease}
.btn-primary:hover::after{left:100%}

/* ═══════════════════════════════════════════
   NAV
   ═══════════════════════════════════════════ */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;height:72px;display:flex;align-items:center;border-bottom:1px solid var(--border);background:rgba(7,7,13,.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);transition:background .3s,box-shadow .3s}
.nav.scrolled{background:rgba(7,7,13,.95);box-shadow:0 4px 30px rgba(0,0,0,0.3)}
.nav-inner{max-width:1120px;margin:0 auto;padding:0 24px;width:100%;display:flex;align-items:center;justify-content:space-between}
.nav-logo-img{height:36px;width:auto;object-fit:contain}
.nav-brand{display:flex;align-items:center;gap:10px}
.nav-brand-name{font-family:'Sora',sans-serif;font-size:20px;font-weight:700;color:var(--text-1);letter-spacing:-.02em}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-link{font-size:14px;color:var(--text-2);transition:color .2s;font-family:'Inter',system-ui,sans-serif}
.nav-link:hover{color:var(--accent)}
.nav-link-highlight{font-size:13px;font-weight:600;color:var(--accent);font-family:'JetBrains Mono',monospace;padding:6px 14px;border:1px solid var(--accent-border);border-radius:6px;background:var(--accent-dim);transition:all .2s}
.nav-link-highlight:hover{background:rgba(0,229,176,0.15);border-color:var(--accent)}
@media(max-width:768px){.nav-links{display:none}.nav{height:60px}.nav-logo-img{height:28px}}

/* ═══════════════════════════════════════════
   TAGS
   ═══════════════════════════════════════════ */
.tag{display:inline-flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--accent);background:var(--accent-dim);border:1px solid var(--accent-border);padding:8px 18px;border-radius:6px}
.tag-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,229,176,.4)}50%{opacity:.6;box-shadow:0 0 0 6px rgba(0,229,176,0)}}

/* ═══════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════ */
.fb-hero{padding:140px 0 48px;text-align:center;position:relative;overflow:hidden}
.fb-hero::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.05) 1px,transparent 1px);background-size:28px 28px;mask-image:radial-gradient(ellipse 60% 50% at 50% 30%,#000 20%,transparent 100%);-webkit-mask-image:radial-gradient(ellipse 60% 50% at 50% 30%,#000 20%,transparent 100%);pointer-events:none}
.fb-hero::after{content:'';position:absolute;top:5%;left:50%;transform:translateX(-50%);width:700px;height:700px;background:radial-gradient(circle,rgba(0,229,176,.05) 0%,transparent 65%);pointer-events:none}
.fb-hero>*{position:relative;z-index:1}
.fb-hero h1{font-size:clamp(30px,4.5vw,54px);font-weight:800;letter-spacing:-.035em;margin:24px auto 20px;max-width:780px;line-height:1.08}
.fb-hero p.hero-sub{font-size:19px;color:var(--text-2);max-width:600px;margin:0 auto;line-height:1.75}

/* ═══════════════════════════════════════════
   HOW IT WORKS STRIP
   ═══════════════════════════════════════════ */
.how-strip{padding:64px 0;border-top:1px solid var(--border)}
.how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;max-width:900px;margin:0 auto}
.how-step{padding:0 32px;border-left:1px solid var(--border);position:relative}
.how-step:first-child{border-left:none;padding-left:0}
.how-num{
  width:44px;height:44px;background:var(--bg-card);border:1px solid var(--accent-border);border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:600;color:var(--accent);margin-bottom:20px;
  transition:background .3s,box-shadow .3s;
}
.how-step:hover .how-num{background:var(--accent-dim);box-shadow:0 0 20px rgba(0,229,176,0.15)}
.how-title{font-size:17px;font-weight:700;color:var(--text-1);margin-bottom:10px;letter-spacing:-.02em}
.how-desc{font-size:15px;color:var(--text-2);line-height:1.7}
@media(max-width:768px){
  .how-grid{grid-template-columns:1fr;gap:32px}
  .how-step{border-left:none!important;padding:0!important;border-top:1px solid var(--border);padding-top:24px!important}
  .how-step:first-child{border-top:none;padding-top:0!important}
}

/* ═══════════════════════════════════════════
   EXAMPLES SECTION
   ═══════════════════════════════════════════ */
.examples{padding:64px 0 0;text-align:center}
.examples-label{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--accent);letter-spacing:.1em;text-transform:uppercase;margin-bottom:24px;display:block}
.examples-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;max-width:900px;margin:0 auto;text-align:left}
.ex-card{background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:22px 20px;transition:border-color .3s,transform .3s}
.ex-card:hover{border-color:var(--border-hover);transform:translateY(-3px)}
.ex-icon{font-size:22px;margin-bottom:10px}
.ex-industry{font-family:'Sora',sans-serif;font-size:13px;font-weight:700;color:var(--text-1);margin-bottom:6px}
.ex-desc{font-size:13px;color:var(--text-3);line-height:1.6}
.ex-time{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);margin-top:10px}
@media(max-width:768px){.examples-grid{grid-template-columns:1fr 1fr}}
@media(max-width:480px){.examples-grid{grid-template-columns:1fr}}

/* ═══════════════════════════════════════════
   FORM SECTION
   ═══════════════════════════════════════════ */
.form-section{padding:80px 0 120px}
.form-card{
  max-width:640px;margin:0 auto;
  background:var(--bg-card);border:1px solid var(--border);
  border-radius:14px;overflow:hidden;transition:border-color .3s;
}
.form-card:hover{border-color:var(--border-hover)}
.form-header{padding:32px 40px 0;border-bottom:none}
.form-header h2{font-size:24px;font-weight:800;letter-spacing:-.03em;margin-bottom:6px}
.form-header p{font-size:14px;color:var(--text-3);line-height:1.6}
.form-body{padding:28px 40px 40px}

.fg{margin-bottom:24px}
.fg label{display:block;font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:8px}
.fg .required{color:var(--accent);margin-left:2px}

.fi{
  width:100%;font-family:'Inter',system-ui,sans-serif;font-size:15px;
  color:var(--text-1);background:var(--bg-elevated);
  border:1px solid var(--border);border-radius:10px;
  padding:14px 18px;outline:none;
  transition:border-color .2s,box-shadow .2s;
}
.fi:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(0,229,176,0.1)}
.fi::placeholder{color:var(--text-3)}

.fi-select{
  appearance:none;cursor:pointer;
  background-image:url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%236E6E90' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat:no-repeat;background-position:right 16px center;
}
.fi-select option{background:var(--bg-card)}

.fi-textarea{min-height:120px;resize:vertical;line-height:1.7}

/* Tool checkboxes */
.tool-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.tool-check{
  display:flex;align-items:center;gap:8px;
  background:var(--bg-elevated);border:1px solid var(--border);
  border-radius:8px;padding:10px 14px;cursor:pointer;
  transition:all .2s;font-size:13px;color:var(--text-2);
  user-select:none;
}
.tool-check:hover{border-color:var(--accent-border)}
.tool-check.checked{border-color:var(--accent);background:var(--accent-dim);color:var(--text-1)}
.tool-check input{display:none}
.tool-dot{width:14px;height:14px;border-radius:4px;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s}
.tool-check.checked .tool-dot{border-color:var(--accent);background:var(--accent)}
.tool-check.checked .tool-dot::after{content:'✓';font-size:10px;color:#07070D;font-weight:700}
@media(max-width:480px){.tool-grid{grid-template-columns:1fr 1fr}}

/* Row layout */
.fg-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:480px){.fg-row{grid-template-columns:1fr}}

/* Submit */
.submit-btn{
  width:100%;font-family:'Sora',sans-serif;font-size:16px;font-weight:700;
  padding:18px 32px;border-radius:10px;border:none;cursor:pointer;
  background:var(--accent);color:#07070D;
  transition:all .25s;position:relative;overflow:hidden;
  box-shadow:0 4px 20px rgba(0,229,176,0.2);
  margin-top:8px;
}
.submit-btn:hover{background:var(--accent-hover);transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,229,176,0.3)}
.submit-btn:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none}
.submit-btn::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);transition:left .5s ease}
.submit-btn:hover::after{left:100%}

.form-footer{
  text-align:center;padding:16px 40px 0;
  font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-3);
}

/* ═══════════════════════════════════════════
   SUCCESS STATE
   ═══════════════════════════════════════════ */
.success-state{display:none;text-align:center;padding:60px 40px}
.success-state.active{display:block;animation:fadeUp .5s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.success-icon{font-size:56px;margin-bottom:20px}
.success-state h2{font-size:28px;font-weight:800;margin-bottom:12px;letter-spacing:-.03em}
.success-state p{font-size:16px;color:var(--text-2);line-height:1.7;max-width:440px;margin:0 auto}
.success-state .next-steps{margin-top:32px;text-align:left;max-width:400px;margin-left:auto;margin-right:auto}
.next-step{display:flex;align-items:flex-start;gap:14px;margin-bottom:18px}
.ns-num{
  width:32px;height:32px;background:var(--accent-dim);border:1px solid var(--accent-border);border-radius:8px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;color:var(--accent);
}
.ns-text{font-size:14px;color:var(--text-2);line-height:1.6;padding-top:4px}
.ns-text strong{color:var(--text-1);font-weight:600}

/* ═══════════════════════════════════════════
   PROOF BAR
   ═══════════════════════════════════════════ */
.proof-bar{
  padding:48px 0;border-top:1px solid var(--border);
}
.proof-inner{
  display:flex;justify-content:center;gap:48px;flex-wrap:wrap;
  font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--text-3);
}
.proof-item{display:flex;align-items:center;gap:10px}
.proof-num{font-family:'Sora',sans-serif;font-size:28px;font-weight:800;color:var(--accent);line-height:1}
.proof-label{font-size:12px;color:var(--text-3);line-height:1.4}

/* ═══════════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════════ */
.footer{border-top:1px solid var(--border);padding:48px 0}
.footer-inner{display:flex;flex-direction:column;align-items:center;gap:28px}
.footer-brand{display:flex;align-items:center;gap:10px}
.footer-logo-img{height:40px;width:auto;object-fit:contain}
.footer-brand-name{font-family:'Sora',sans-serif;font-size:18px;font-weight:700;color:var(--text-1)}
.footer-links{display:flex;gap:28px;flex-wrap:wrap;justify-content:center}
.footer-link{font-size:15px;color:var(--text-3);transition:color .2s}
.footer-link:hover{color:var(--accent)}
.footer-copy{font-size:13px;color:var(--text-3);font-family:'JetBrains Mono',monospace}

@media(max-width:600px){
  .fb-hero{padding:110px 0 40px}
  .fb-hero h1{font-size:26px}
  .form-header,.form-body{padding-left:24px;padding-right:24px}
  .success-state{padding:40px 24px}
  .proof-inner{gap:24px}
}
</style>
</head>
